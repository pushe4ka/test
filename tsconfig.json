{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "rootDir": "ts",
    "outDir": "js",
    "esModuleInterop": true, //support for importing CommonJS modules
    "forceConsistentCasingInFileNames": true, //Ensure that casing is correct in imports
    "strict": true, //strict type-checking options.
    "skipLibCheck": true //Skip type checking all .d.ts files. Пропускає перевірку типів у файлах бібліотек, прискорює компіляцію
  },
    "include": ["ts/**/*"] //вказує, що компілювати
}

